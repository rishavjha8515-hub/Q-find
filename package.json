{
  "name":"q-find",
  "version":"1.0.0",
  "description": "Quantum-cryptographic urban scavenger hunt",
  "main": "server/index.js",
  "scripts": {
    "start":"node server/index.js",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" ",
    "build": "cd client && npm install && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "keywords": [
    "scavenger-hunt",
    "quantum",
    "hackclub"
  ],
  "author": "Rishav Jha",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}